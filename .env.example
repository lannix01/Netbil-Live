APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Nairobi

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PettyCash API token expiry (days)
PETTY_API_VERSION=v1
PETTY_API_TOKEN_TTL_DAYS=30
PETTY_API_TOKEN_IDLE_TTL_MINUTES=0
PETTY_API_TOKEN_REFRESH_ON_USE=false
PETTY_API_MAX_ACTIVE_TOKENS_PER_USER=10
PETTY_API_RATE_LIMIT_PER_MINUTE=120
PETTY_API_LOGIN_RATE_LIMIT_PER_MINUTE=20
PETTY_API_DEPRECATED=false
PETTY_API_SUNSET_AT=
PETTY_ONT_DIRECTORY_ENABLED=true
PETTY_ONT_STRICT_VALIDATION=true
PETTY_ONT_ENDPOINT=https://api.skybrix.co.ke/v1/onts
PETTY_ONT_USERNAME=
PETTY_ONT_PASSWORD=
PETTY_ONT_TIMEOUT_SECONDS=12
PETTY_ONT_CACHE_TTL_SECONDS=300
INVENTORY_ROUTER_API_ENABLED=true
INVENTORY_ROUTER_API_BASE_URL=https://api.skybrix.co.ke/v1
INVENTORY_ROUTER_API_USERNAME=
INVENTORY_ROUTER_API_PASSWORD=
INVENTORY_ROUTER_API_TIMEOUT_SECONDS=12
INVENTORY_ROUTER_API_PAGE_SIZE=20
INVENTORY_ROUTER_API_MAX_PAGE_SIZE=100

NETBIL_DEMO_PIN=808080
NETBIL_DEMO_RATE_LIMIT_PER_MINUTE=6
